{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f astro.config.mjs ] && npx astro check --minimumSeverity error 2>&1 | tail -20 || true",
            "timeout": 60,
            "statusMessage": "astro check..."
          }
        ]
      }
    ]
  }
}
