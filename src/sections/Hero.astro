---
import logo from '../../public/images/logo-norson.png'
---

<section class="flex flex-col min-h-svh bg-[#1a3a5c] px-5 lg:px-0 lg:min-h-0">
  <nav class="hidden lg:flex items-center justify-between h-[72px] px-10 bg-[#1a3a5c] w-full">
    <div class="flex items-center gap-3">
      <img
        src={logo.src}
        alt="NorSon Supplies"
        width="120"
        height="66"
        fetchpriority="high"
        loading="eager"
      />
      <span class="text-white font-bold text-xl tracking-wide">NorSon Supplies</span>
    </div>
    <a
      href="tel:6313035892"
      class="flex items-center gap-2 text-white text-base font-medium hover:text-white/80 transition-colors"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.27h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.73a16 16 0 0 0 6 6l.73-.73a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7a2 2 0 0 1 1.72 2z"/>
      </svg>
      Llamar: 631 303 5892
    </a>
  </nav>

  <div class="flex flex-col lg:flex-row flex-1 lg:min-h-[calc(100vh-72px)]">
    <div class="flex flex-col items-center lg:items-start lg:justify-center lg:w-[55%] lg:px-16 lg:py-16 flex-1 lg:flex-none">
      <div class="flex justify-center items-center gap-3 lg:hidden pt-6 w-full">
        <img
          src="/images/logo-norson.png"
          alt="NorSon Supplies"
          width="120"
          height="66"
          fetchpriority="high"
          loading="eager"
        />
        <span class="text-white font-bold text-xl tracking-wide">NorSon Supplies</span>
      </div>

      <h1 class="text-[28px] lg:text-5xl font-bold text-white text-center lg:text-left leading-tight mt-6 lg:mt-0">
        Materiales de construcci&oacute;n en Sinaloa, listos cuando los necesitas
      </h1>

      <p class="text-base text-white/85 text-center lg:text-left mt-3">
        Venta de materiales, renta de maquinaria y asesor&iacute;a en proyectos. Servicio directo, sin intermediarios.
      </p>

      <div class="flex flex-col lg:flex-row items-stretch lg:items-center gap-3 w-full mt-8">
        <a
          href="https://wa.me/526313035892"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center justify-center gap-3 w-full lg:w-auto lg:px-8 h-[52px] bg-[#f97316] text-white text-lg font-semibold rounded-lg"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/>
          </svg>
          Cotiza por WhatsApp
        </a>

        <a
          href="tel:6313035892"
          class="flex items-center justify-center gap-3 w-full lg:w-auto lg:px-8 h-[44px] border border-white text-white text-base rounded-lg"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.27h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.73a16 16 0 0 0 6 6l.73-.73a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7a2 2 0 0 1 1.72 2z"/>
          </svg>
          Llamar: 631 303 5892
        </a>
      </div>

      <ul class="flex flex-col lg:flex-row items-center lg:items-start gap-2 lg:gap-6 mt-6 list-none pb-8 lg:pb-0">
        <li class="text-sm text-white/70 text-center lg:text-left">
          &bull; +80 productos disponibles
        </li>
        <li class="text-sm text-white/70 text-center lg:text-left">
          &bull; Renta de maquinaria
        </li>
        <li class="text-sm text-white/70 text-center lg:text-left">
          &bull; Atenci&oacute;n en obra
        </li>
      </ul>
    </div>

    <div class="hidden lg:block lg:w-[45%] bg-[#f97316] relative overflow-hidden">
      <div class="absolute inset-0 opacity-20" style="background-image: repeating-linear-gradient(45deg, #ffffff 0, #ffffff 1px, transparent 0, transparent 50%); background-size: 24px 24px;"></div>
      <div class="absolute -left-16 top-1/4 w-48 h-48 rounded-full border-4 border-white/30"></div>
      <div class="absolute right-10 bottom-1/4 w-32 h-32 rounded-full border-4 border-white/20"></div>
      <div class="absolute left-1/3 top-1/2 -translate-y-1/2 w-24 h-24 rotate-45 border-4 border-white/25"></div>
    </div>
  </div>
</section>
