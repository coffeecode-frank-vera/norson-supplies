---
import logo from '../../public/images/logo-norson.png'
---

<section
  id="inicio"
  class="relative flex flex-col min-h-svh overflow-hidden lg:min-h-0"
  style="background: linear-gradient(135deg, #0c2540 0%, #1a3a5c 55%, #1e4470 100%);"
>
  <!-- Floating ambient orbs -->
  <div
    class="absolute top-[6%] left-[2%] w-64 h-64 lg:w-96 lg:h-96 rounded-full bg-white/[0.04] blur-3xl pointer-events-none [animation:float_10s_ease-in-out_infinite]"
    aria-hidden="true"
  ></div>
  <div
    class="absolute bottom-[8%] left-[12%] w-48 h-48 lg:w-64 lg:h-64 rounded-full blur-3xl pointer-events-none [animation:float-alt_13s_ease-in-out_infinite_3s]"
    style="background: rgba(249,115,22,0.08);"
    aria-hidden="true"
  ></div>
  <div
    class="absolute top-[42%] left-[28%] w-40 h-40 lg:w-48 lg:h-48 rounded-full bg-white/[0.03] blur-2xl pointer-events-none [animation:float_8s_ease-in-out_infinite_1.5s]"
    aria-hidden="true"
  ></div>

  <!-- ─── Mobile header ─────────────────────────────────── -->
  <header
    class="lg:hidden flex items-center justify-between px-5 pt-5 pb-4 relative z-10 [animation:fade-in_0.5s_ease-out_both]"
  >
    <div class="flex items-center gap-2.5">
      <img
        src={logo.src}
        alt="NorSon Supplies"
        width="48"
        height="26"
        fetchpriority="high"
        loading="eager"
        class="brightness-0 invert"
      />
      <span class="text-white font-bold text-[15px] tracking-wide">NorSon Supplies</span>
    </div>
    <a
      href="tel:6313035892"
      class="flex items-center gap-1.5 bg-white/15 border border-white/20 text-white text-xs font-semibold px-3 py-2 rounded-full"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="13"
        height="13"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.27h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.73a16 16 0 0 0 6 6l.73-.73a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7a2 2 0 0 1 1.72 2z"/>
      </svg>
      Llamar
    </a>
  </header>

  <!-- ─── Desktop nav ───────────────────────────────────── -->
  <nav
    aria-label="Encabezado"
    class="hidden lg:flex items-center justify-between h-[72px] px-10 w-full relative z-10 [animation:fade-in_0.7s_ease-out_both]"
  >
    <div class="flex items-center gap-3">
      <img
        src={logo.src}
        alt="NorSon Supplies"
        width="120"
        height="66"
        fetchpriority="high"
        loading="eager"
      />
      <span class="text-white font-bold text-xl tracking-wide">NorSon Supplies</span>
    </div>
    <div class="flex items-center gap-8">
      <a href="#nosotros" class="text-white/70 hover:text-white text-sm transition-colors">Nosotros</a>
      <a href="#productos" class="text-white/70 hover:text-white text-sm transition-colors">Productos</a>
      <a href="#contacto" class="text-white/70 hover:text-white text-sm transition-colors">Contacto</a>
      <a
        href="tel:6313035892"
        class="flex items-center gap-2 text-white text-sm font-medium bg-white/10 hover:bg-white/20 transition-colors px-4 py-2 rounded-full border border-white/20"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.27h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.73a16 16 0 0 0 6 6l.73-.73a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7a2 2 0 0 1 1.72 2z"/>
        </svg>
        631 303 5892
      </a>
    </div>
  </nav>

  <!-- ─── Main layout ───────────────────────────────────── -->
  <div class="flex flex-col lg:flex-row flex-1 lg:min-h-[calc(100vh-72px)] relative z-10">

    <!-- Left: content -->
    <div
      class="flex flex-col items-center justify-center lg:items-start lg:justify-center lg:w-[55%] lg:px-16 lg:py-16 flex-1 lg:flex-none px-5 py-8 lg:px-0 lg:py-0"
    >

      <!-- Location badge (mobile only) -->
      <div class="lg:hidden mb-5 [animation:fade-in_0.6s_ease-out_0.1s_both]">
        <span class="inline-flex items-center gap-2 bg-white/10 border border-white/15 text-white/80 text-xs font-medium px-3 py-1.5 rounded-full">
          <span class="w-1.5 h-1.5 rounded-full bg-[#f97316] shrink-0" aria-hidden="true"></span>
          Distribuidora en Sinaloa
        </span>
      </div>

      <h1
        class="text-[30px] lg:text-5xl font-bold text-white text-center lg:text-left leading-tight [animation:fade-up_0.8s_ease-out_0.15s_both]"
      >
        Materiales de construcci&oacute;n en Sinaloa, listos cuando los necesitas
      </h1>

      <p
        class="text-[15px] lg:text-base text-white/80 text-center lg:text-left mt-4 lg:mt-3 leading-relaxed max-w-sm lg:max-w-none [animation:fade-up_0.8s_ease-out_0.3s_both]"
      >
        Venta de materiales, renta de maquinaria y asesor&iacute;a en proyectos. Servicio directo,
        sin intermediarios.
      </p>

      <!-- CTAs -->
      <div
        class="w-full mt-7 lg:mt-8 [animation:fade-up_0.8s_ease-out_0.45s_both]"
      >
        <!-- Primary CTA: full width on both -->
        <a
          href="https://wa.me/526313035892"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center justify-center gap-3 w-full lg:w-auto lg:px-8 h-[54px] bg-[#f97316] text-white text-base lg:text-lg font-semibold rounded-xl btn-shimmer [animation:pulse-glow_3s_ease-in-out_1s_infinite]"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="22"
            height="22"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/>
          </svg>
          Cotiza por WhatsApp
        </a>

        <!-- Secondary CTA: text link on mobile, button on desktop -->
        <div class="flex items-center justify-center mt-3 lg:hidden">
          <a
            href="tel:6313035892"
            class="flex items-center gap-2 text-white/60 text-sm hover:text-white/80 transition-colors"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.27h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.73a16 16 0 0 0 6 6l.73-.73a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7a2 2 0 0 1 1.72 2z"/>
            </svg>
            o llama al <span class="text-white/80 font-medium ml-1">631 303 5892</span>
          </a>
        </div>

        <!-- Desktop secondary button -->
        <a
          href="tel:6313035892"
          class="hidden lg:flex items-center justify-center gap-3 lg:w-auto lg:px-8 h-[44px] border border-white/60 text-white text-base rounded-lg hover:bg-white/10 transition-colors duration-300 mt-3"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.27h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.73a16 16 0 0 0 6 6l.73-.73a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7a2 2 0 0 1 1.72 2z"/>
          </svg>
          Llamar: 631 303 5892
        </a>
      </div>

      <!-- Trust bullets -->
      <div
        class="flex items-center justify-center lg:justify-start flex-wrap gap-x-4 gap-y-1.5 mt-6 pb-6 lg:pb-0 [animation:fade-up_0.8s_ease-out_0.6s_both]"
      >
        <span class="flex items-center gap-1.5 text-xs text-white/55">
          <span class="w-1 h-1 rounded-full bg-[#f97316] shrink-0" aria-hidden="true"></span>
          +80 productos
        </span>
        <span class="flex items-center gap-1.5 text-xs text-white/55">
          <span class="w-1 h-1 rounded-full bg-[#f97316] shrink-0" aria-hidden="true"></span>
          Renta de maquinaria
        </span>
        <span class="flex items-center gap-1.5 text-xs text-white/55">
          <span class="w-1 h-1 rounded-full bg-[#f97316] shrink-0" aria-hidden="true"></span>
          Atenci&oacute;n en obra
        </span>
      </div>
    </div>

    <!-- Right: decorative orange panel (desktop only) -->
    <div class="hidden lg:block lg:w-[45%] bg-[#f97316] relative overflow-hidden">

      <div
        class="absolute inset-0 opacity-[0.18] [animation:pan-diagonal_3s_linear_infinite]"
        style="background-image: repeating-linear-gradient(45deg, #fff 0, #fff 1px, transparent 0, transparent 50%); background-size: 24px 24px;"
        aria-hidden="true"
      ></div>

      <div
        class="absolute inset-0"
        style="background: linear-gradient(135deg, rgba(200,90,10,0.35) 0%, transparent 50%, rgba(249,115,22,0.1) 100%);"
        aria-hidden="true"
      ></div>

      <div class="absolute inset-0 flex items-center justify-center opacity-[0.13]" aria-hidden="true">
        <svg viewBox="0 0 280 360" width="280" height="360" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect x="20" y="80" width="240" height="280" stroke="white" stroke-width="3"/>
          <path d="M0 80 L140 18 L280 80" stroke="white" stroke-width="3" fill="none"/>
          <circle cx="140" cy="18" r="5" fill="white"/>
          <line x1="20" y1="140" x2="260" y2="140" stroke="white" stroke-width="1.5"/>
          <line x1="20" y1="200" x2="260" y2="200" stroke="white" stroke-width="1.5"/>
          <line x1="20" y1="260" x2="260" y2="260" stroke="white" stroke-width="1.5"/>
          <line x1="100" y1="80" x2="100" y2="360" stroke="white" stroke-width="1.5"/>
          <line x1="180" y1="80" x2="180" y2="360" stroke="white" stroke-width="1.5"/>
          <rect x="30" y="94" width="55" height="34" stroke="white" stroke-width="1.5"/>
          <rect x="112" y="94" width="56" height="34" stroke="white" stroke-width="1.5"/>
          <rect x="195" y="94" width="55" height="34" stroke="white" stroke-width="1.5"/>
          <rect x="30" y="154" width="55" height="34" stroke="white" stroke-width="1.5"/>
          <rect x="112" y="154" width="56" height="34" stroke="white" stroke-width="1.5"/>
          <rect x="195" y="154" width="55" height="34" stroke="white" stroke-width="1.5"/>
          <rect x="30" y="214" width="55" height="34" stroke="white" stroke-width="1.5"/>
          <rect x="112" y="214" width="56" height="34" stroke="white" stroke-width="1.5"/>
          <rect x="195" y="214" width="55" height="34" stroke="white" stroke-width="1.5"/>
          <rect x="108" y="290" width="64" height="70" stroke="white" stroke-width="2"/>
          <line x1="140" y1="290" x2="140" y2="360" stroke="white" stroke-width="1"/>
          <circle cx="130" cy="325" r="2.5" fill="white"/>
        </svg>
      </div>

      <div
        class="absolute -left-16 top-1/4 w-48 h-48 rounded-full border-4 border-white/30 [animation:float_7s_ease-in-out_infinite]"
        aria-hidden="true"
      ></div>
      <div
        class="absolute right-10 bottom-1/4 w-32 h-32 rounded-full border-4 border-white/20 [animation:float-alt_9s_ease-in-out_infinite_1.5s]"
        aria-hidden="true"
      ></div>
      <div class="absolute left-1/3 top-1/2 -translate-y-1/2" aria-hidden="true">
        <div class="w-24 h-24 border-4 border-white/25 [animation:spin-diamond_22s_linear_infinite]"></div>
      </div>
      <div
        class="absolute -bottom-20 -right-20 w-80 h-80 rounded-full border-[28px] border-white/10 [animation:float-alt_14s_ease-in-out_infinite_4s]"
        aria-hidden="true"
      ></div>
      <div
        class="absolute top-12 right-12 w-20 h-20 rounded-full border-2 border-white/20 [animation:float_6s_ease-in-out_infinite_2s]"
        aria-hidden="true"
      ></div>
    </div>
  </div>
</section>
