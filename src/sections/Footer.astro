---
const year = new Date().getFullYear()
---

<footer class="bg-[#1a3a5c] text-white py-12 px-6">
  <div class="max-w-6xl mx-auto">

    <div class="flex flex-col gap-10 md:grid md:grid-cols-3 md:gap-12">

      <div>
        <img
          src="/images/logo-norson.png"
          alt="NorSon Supplies"
          width="140"
          height="40"
          loading="lazy"
          class="brightness-0 invert"
        />
        <p class="font-semibold text-white mt-3">NorSon Supplies</p>
        <p class="text-white/70 text-sm mt-1">
          Materiales de construcción en Sinaloa — respaldo, calidad y entrega.
        </p>
      </div>

      <div>
        <p class="text-white/50 text-xs uppercase tracking-widest mb-3">Contacto</p>
        <ul class="space-y-2">
          <li>
            <a
              href="tel:6313035892"
              class="text-white/80 hover:text-white transition-colors py-2 inline-block"
            >
              631 303 5892
            </a>
          </li>
          <li>
            <a
              href="https://wa.me/526313035892"
              target="_blank"
              rel="noopener noreferrer"
              class="text-white/80 hover:text-white transition-colors py-2 inline-block"
            >
              WhatsApp
            </a>
          </li>
          <li>
            <a
              href="mailto:Yolanda.padilla@galetadistribuidora.com"
              class="text-white/80 hover:text-white transition-colors py-2 inline-block break-all"
            >
              Yolanda.padilla@galetadistribuidora.com
            </a>
          </li>
          <li>
            <p class="text-white/70 text-sm py-2">Sinaloa, noroeste de México</p>
          </li>
        </ul>
      </div>

      <div>
        <p class="text-white/50 text-xs uppercase tracking-widest mb-3">Navegación</p>
        <nav aria-label="Footer">
          <ul class="space-y-2">
            <li>
              <a
                href="#inicio"
                class="text-white/80 hover:text-white transition-colors py-2 inline-block"
              >
                Inicio
              </a>
            </li>
            <li>
              <a
                href="#nosotros"
                class="text-white/80 hover:text-white transition-colors py-2 inline-block"
              >
                Nosotros
              </a>
            </li>
            <li>
              <a
                href="#productos"
                class="text-white/80 hover:text-white transition-colors py-2 inline-block"
              >
                Productos
              </a>
            </li>
            <li>
              <a
                href="#contacto"
                class="text-white/80 hover:text-white transition-colors py-2 inline-block"
              >
                Contacto
              </a>
            </li>
          </ul>
        </nav>
      </div>

    </div>

    <div class="border-t border-white/10 mt-10 pt-6">
      <p class="text-white/50 text-sm text-center">
        &copy; {year} NorSon Supplies. Todos los derechos reservados.
      </p>
      <p class="text-white/40 text-xs text-center mt-1">
        Distribuidora de materiales de construcción en Sinaloa.
      </p>
    </div>

  </div>
</footer>
