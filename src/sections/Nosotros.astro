---
interface Value {
  label: string
  description: string
  icon: string
}

const values: Value[] = [
  {
    label: "Entrega puntual",
    description: "El material llega cuando lo necesitas, no cuando nos convenga.",
    icon: "truck",
  },
  {
    label: "Inventario completo",
    description: "De cementos a acero — todo en un solo proveedor.",
    icon: "cube",
  },
  {
    label: "Calidad verificada",
    description: "Solo marcas y lotes que pasan nuestro control antes de salir.",
    icon: "shield-check",
  },
  {
    label: "Trato directo",
    description: "Sin intermediarios: hablas con quien decide.",
    icon: "chat-bubble",
  },
  {
    label: "Presencia regional",
    description: "Conocemos las obras del noroeste porque estamos en Sonora, no en un call center.",
    icon: "map-pin",
  },
  {
    label: "Precio transparente",
    description: "El precio que te cotizamos es el que pagas — sin sorpresas al facturar.",
    icon: "currency-dollar",
  },
]
---

<section
  id="nosotros"
  class="relative py-16 md:py-24 px-5 md:px-10 lg:px-0 overflow-hidden"
  style="background: radial-gradient(ellipse 70% 50% at 10% 20%, rgba(30,100,160,0.35) 0%, transparent 55%), radial-gradient(ellipse 60% 70% at 90% 80%, rgba(249,115,22,0.12) 0%, transparent 50%), #0a1929;"
>
  <!-- Ambient orb -->
  <div
    class="absolute top-[10%] right-[5%] w-72 h-72 lg:w-[500px] lg:h-[500px] rounded-full bg-white/[0.04] blur-3xl pointer-events-none"
    aria-hidden="true"
  ></div>

  <div class="max-w-5xl mx-auto relative z-10">

    <div data-reveal class="text-center mb-10 md:mb-14">
      <p class="text-xs font-semibold tracking-widest uppercase text-white/50 mb-3">
        Sobre nosotros
      </p>
      <h2 class="text-2xl md:text-4xl font-bold text-white leading-tight max-w-2xl mx-auto">
        Una distribuidora que trabaja para que tu obra no se detenga
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-10 md:mb-12">
      <div
        data-reveal
        data-delay="100"
        class="border-l-4 border-[#f97316] rounded-r-lg p-6 backdrop-blur-sm hover:-translate-y-0.5 transition-all duration-300"
        style="background: rgba(255,255,255,0.07); border-top: 1px solid rgba(255,255,255,0.1); border-right: 1px solid rgba(255,255,255,0.1); border-bottom: 1px solid rgba(255,255,255,0.1);"
      >
        <h3 class="text-base font-semibold text-white mb-2">Nuestra promesa</h3>
        <p class="text-base text-white/70 leading-relaxed">
          Llevamos materiales de construcción de calidad comprobada directamente al sitio de trabajo
          del contratista — con el surtido completo, el precio justo y la entrega que no detiene la obra.
        </p>
      </div>

      <div
        data-reveal
        data-delay="200"
        class="border-l-4 border-[#f97316] rounded-r-lg p-6 backdrop-blur-sm hover:-translate-y-0.5 transition-all duration-300"
        style="background: rgba(255,255,255,0.07); border-top: 1px solid rgba(255,255,255,0.1); border-right: 1px solid rgba(255,255,255,0.1); border-bottom: 1px solid rgba(255,255,255,0.1);"
      >
        <h3 class="text-base font-semibold text-white mb-2">Nuestro compromiso con la región</h3>
        <p class="text-base text-white/70 leading-relaxed">
          Ser el distribuidor de referencia en el noroeste de México: el que el contratista llama
          primero porque sabe que siempre hay material, siempre hay respuesta y siempre hay trato directo.
        </p>
      </div>
    </div>

    <!-- Stats bar -->
    <div
      data-reveal
      class="grid grid-cols-3 gap-2 md:gap-4 mb-12 md:mb-16 py-6 md:py-8 rounded-xl backdrop-blur-sm"
      style="background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12);"
    >
      <div class="text-center px-1 md:px-4">
        <p class="text-3xl md:text-4xl lg:text-5xl font-bold text-[#f97316]">
          <span data-count="80" data-suffix="+">80+</span>
        </p>
        <p class="text-[10px] md:text-sm text-white/50 mt-1 font-medium leading-tight">productos<br class="md:hidden"/> disponibles</p>
      </div>
      <div class="text-center px-1 md:px-4" style="border-left: 1px solid rgba(255,255,255,0.12); border-right: 1px solid rgba(255,255,255,0.12);">
        <p class="text-3xl md:text-4xl lg:text-5xl font-bold text-[#f97316]">
          <span data-count="12">12</span>
        </p>
        <p class="text-[10px] md:text-sm text-white/50 mt-1 font-medium leading-tight">categorías<br class="md:hidden"/> de materiales</p>
      </div>
      <div class="text-center px-1 md:px-4">
        <p class="text-3xl md:text-4xl lg:text-5xl font-bold text-[#f97316]">1:1</p>
        <p class="text-[10px] md:text-sm text-white/50 mt-1 font-medium leading-tight">trato<br class="md:hidden"/> directo</p>
      </div>
    </div>

    <!-- Values grid -->
    <div class="grid grid-cols-2 md:grid-cols-3 gap-4 mb-12 md:mb-16">
      {values.map((v, i) => (
        <div
          data-reveal
          data-delay={String((i % 3) * 100 + 100)}
          class="group rounded-lg p-5 flex flex-col gap-3 cursor-default backdrop-blur-sm transition-all duration-300 hover:-translate-y-1"
          style="background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1);"
        >
          <div class="w-10 h-10 flex items-center justify-center rounded-md shrink-0 transition-all duration-300 group-hover:scale-110" style="background: rgba(255,255,255,0.1);">
            {v.icon === "truck" && (
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.75)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="group-hover:stroke-[#f97316] transition-colors duration-300">
                <path d="M1 3h13v13H1zM14 8h4l3 3v5h-7V8z"/>
                <circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
              </svg>
            )}
            {v.icon === "cube" && (
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.75)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="group-hover:stroke-[#f97316] transition-colors duration-300">
                <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
                <polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/>
              </svg>
            )}
            {v.icon === "shield-check" && (
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.75)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="group-hover:stroke-[#f97316] transition-colors duration-300">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                <polyline points="9 12 11 14 15 10"/>
              </svg>
            )}
            {v.icon === "chat-bubble" && (
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.75)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="group-hover:stroke-[#f97316] transition-colors duration-300">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                <path d="M8 10h.01M12 10h.01M16 10h.01" stroke-width="2.5"/>
              </svg>
            )}
            {v.icon === "map-pin" && (
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.75)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="group-hover:stroke-[#f97316] transition-colors duration-300">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
            )}
            {v.icon === "currency-dollar" && (
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.75)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="group-hover:stroke-[#f97316] transition-colors duration-300">
                <line x1="12" y1="1" x2="12" y2="23"/>
                <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
              </svg>
            )}
          </div>
          <div>
            <p class="text-sm font-semibold text-white mb-1 group-hover:text-[#f97316] transition-colors duration-300">{v.label}</p>
            <p class="text-sm text-white/60 leading-relaxed">{v.description}</p>
          </div>
        </div>
      ))}
    </div>

    <div data-reveal class="flex justify-center">
      <a
        href="https://wa.me/526313035892"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center min-h-[44px] w-full max-w-[280px] md:w-auto md:px-8 border-2 border-white/30 text-white text-base font-semibold rounded-lg transition-all duration-300 hover:bg-white/10 hover:border-white/50 hover:shadow-lg btn-shimmer"
      >
        Habla con un asesor &rarr;
      </a>
    </div>

  </div>
</section>
