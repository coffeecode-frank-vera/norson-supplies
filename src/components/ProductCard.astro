---
import { Image } from 'astro:assets'
import type { ImageMetadata } from 'astro'

interface Props {
  nombre: string
  descripcion: string
  categoria: string
  imagen: ImageMetadata | null
  eager?: boolean
}

const { nombre, descripcion, categoria, imagen, eager = false } = Astro.props

const waHref = (name: string) =>
  `https://wa.me/526313035892?text=${encodeURIComponent(`Hola, me interesa cotizar: ${name}`)}`

const initial = nombre.charAt(0).toUpperCase()
---

<article
  class="group bg-white rounded-lg shadow-sm border border-[#e2e8f0] overflow-hidden flex flex-col hover:-translate-y-2 hover:shadow-xl hover:border-[#f97316]/30 transition-all duration-300"
  data-categoria={categoria}
>
  <div class="relative aspect-square w-full overflow-hidden">
    {imagen ? (
      <Image
        src={imagen}
        alt={`${nombre} — ${categoria}`}
        width={400}
        height={400}
        loading={eager ? 'eager' : 'lazy'}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
      />
    ) : (
      <div class="w-full h-full bg-[#1a3a5c] flex items-center justify-center group-hover:scale-105 transition-transform duration-500">
        <span class="text-5xl font-bold text-white select-none">{initial}</span>
      </div>
    )}
    <span class="absolute bottom-2 left-2 bg-black/50 text-white text-xs font-medium px-2 py-0.5 rounded-full group-hover:bg-[#f97316]/90 transition-colors duration-300">
      {categoria}
    </span>
  </div>

  <div class="flex flex-col flex-1 p-3">
    <h3 class="font-semibold text-base text-[#1e293b] leading-snug group-hover:text-[#1a3a5c] transition-colors duration-200">{nombre}</h3>
    <p class="text-sm text-[#64748b] mt-1 line-clamp-2 flex-1">{descripcion}</p>
  </div>

  <a
    href={waHref(nombre)}
    target="_blank"
    rel="noopener noreferrer"
    class="flex items-center justify-center gap-2 w-full min-h-[44px] bg-[#f97316] text-white text-sm font-semibold rounded-b-lg px-3 py-2 btn-shimmer"
    aria-label={`Cotizar ${nombre} por WhatsApp`}
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/>
    </svg>
    <span class="sm:hidden">Cotizar</span>
    <span class="hidden sm:inline">Cotizar por WhatsApp</span>
  </a>
</article>
